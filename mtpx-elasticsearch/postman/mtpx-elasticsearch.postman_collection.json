    {
      "name": "Products - CRUD",
      "description": "Criar, ler, atualizar e deletar documentos de produto no índice `products`.",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Product created', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has product id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.be.a('string');",
                  "    pm.expect(jsonData.result).to.be.a('string');",
                  "    pm.expect(jsonData.product).to.be.an('object');",
                  "});",
                  "",
                  "// Save product ID for later tests",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.environment.set('productId', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gaming Laptop Pro\",\n  \"description\": \"High-performance gaming laptop with RTX 4080 and 32GB RAM\",\n  \"category\": \"Electronics\",\n  \"price\": 2499.99,\n  \"stock\": 15,\n  \"tags\": [\"gaming\", \"laptop\", \"high-performance\"],\n  \"active\": true\n}"
