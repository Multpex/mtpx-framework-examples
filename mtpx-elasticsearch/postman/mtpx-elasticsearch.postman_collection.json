    {
      "name": "Admin - Index Management",
      "description": "Criar e deletar o índice Elasticsearch `products`. Execute Setup Index antes de usar os endpoints CRUD/search.",
      "item": [
        {
          "name": "Setup Index",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Index setup successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has message and created flag', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.be.a('string');",
                  "    pm.expect(jsonData.created).to.be.a('boolean');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/es/admin/index/setup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "es",
                "admin",
                "index",
                "setup"
              ]
            },
            "description": "Cria o índice `products` no Elasticsearch com todos os mappings e settings. Seguro para chamar com índice existente — retorna `created: false`."
          },
          "response": []
        },
        {
          "name": "Delete Index",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Index deleted', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/es/admin/index",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "es",
                "admin",
                "index"
              ]
            },
            "description": "Deleta permanentemente o índice `products` e todos os documentos. Retorna 404 se o índice não existir."
          },
          "response": []
