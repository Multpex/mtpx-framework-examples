        {
          "name": "Bulk Index Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Bulk index returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Bulk response is valid', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.succeeded).to.be.a('number');",
                  "    pm.expect(jsonData.failed).to.be.a('number');",
                  "    pm.expect(jsonData.errors).to.be.a('boolean');",
                  "    pm.expect(jsonData.succeeded).to.be.greaterThan(0);",
                  "    pm.expect(jsonData.errors).to.equal(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
